---
import HeaderLink from "./HeaderLink.astro";
const base = import.meta.env.BASE_URL;
---

<header class="navbar">
  <!-- LEFT: Logo -->
  <div class="left">
    <a class="logo" href={`${base}`}>
      <img src={`${base}/images/full_logo.png`} alt="Logo" />
    </a>
  </div>

  <!-- CENTER: Pages -->
  <nav class="center">
    <HeaderLink href={`${base}/games`}>Games</HeaderLink>
    <HeaderLink href={`${base}/about`}>About</HeaderLink>
    <!-- <HeaderLink href={`${base}/news`}>News</HeaderLink> -->
    <HeaderLink href={`${base}/docs/tos`}>Docs</HeaderLink>
  </nav>

  <!-- RIGHT: Actions -->
  <div class="right">
    <a href="https://youtube.com/@garantystudios" target="_blank" aria-label="YouTube">
      <img src={`${base}/icons/yt.svg`} alt="YouTube" />
    </a>
    <a href="https://x.com/GarantyStudios" target="_blank" aria-label="X">
      <img src={`${base}/icons/x.svg`} alt="X" />
    </a>
      <a href="https://discord.gg/37HGpjm3kx" target="_blank" aria-label="Discord">
      <img src={`${base}/icons/dc.svg`} alt="Discord" />
    </a>
  </div>
</header>

<style>
.navbar {
  display: flex;
  justify-content: space-between;
  align-items: center;

  padding: 0 32px;
  height: 72px;

  position: sticky;
  z-index: 1000;
  top: 0;
  backdrop-filter: blur(12px);
  box-shadow: 0 6px 24px rgba(0,0,0,0.08);

  background: color-mix(in srgb, var(--bg) 85%, transparent);

  transition: all 0.3s ease;
}

.left .logo {
  font-weight: 700;
  font-size: 32px;
  text-decoration: none;
}

.center {
  display: flex;
  gap: 24px;
}

.right {
  display: flex;
  gap: 12px;
  align-items: center;
}

a, button {
  background: none;
  border: none;
  cursor: pointer;
  text-decoration: none;
  opacity: 0.8;
  transition: 0.2s ease;
  color: inherit;
}

a:hover, button:hover {
  opacity: 1;
  transform: translateY(-2px);
}
/* Logo + icons */
.logo img {
  height: auto;
  max-height: 60px;
  width: auto;
  aspect-ratio: 16 / 9;
  object-fit: contain;
  display: block;
}

.right img {
  width: 32px;
  height: auto;
  max-height: 32px;
  object-fit: contain;
  display: block;
}

</style>