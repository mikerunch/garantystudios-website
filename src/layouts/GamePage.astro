---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';


const { title, description, pubDate, updatedDate, heroImage, link, score } = Astro.props;
const base = import.meta.env.BASE_URL;

---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<base href={base} />

		<style>
			main {
				width: calc(100% - 2em);
				max-width: 1100px;
				margin: 0 auto;
				padding: 2rem 0;
			}

			.layout {
				display: grid;
				grid-template-columns: 380px 1fr;
				gap: 2rem;
				align-items: start;
			}

			.hero-image {
				width: 100%;
				border-radius: 14px;
				overflow: hidden;
				box-shadow: var(--box-shadow);
				aspect-ratio: 2 / 3;
			}

			.hero-image img {
				width: 100%;
				height: 100%;
				display: block;
				object-fit: cover;
				transition: transform 0.3s ease;
			}

			.hero-image :global(img) {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
			}

			.hero-image:hover img {
				transform: scale(1.03);
			}

			.prose {
				color: rgb(var(--gray-dark));
			}

			.title {
				margin-bottom: 0.5rem;
			}

			.title h1 {
				margin: 0 0 0.3rem 0;
				font-size: 2rem;
			}

			.description {
				margin-bottom: 1rem;
				color: rgb(var(--gray-dark));
				line-height: 1.6;
			}

			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
				font-size: 0.9rem;
			}

			.last-updated-on {
				font-style: italic;
			}

			.button {
				margin-top: 1.5rem;
				display: inline-flex;
				padding: 0.9rem 1.2rem;
				border-radius: 12px;
				background: linear-gradient(135deg, #6d5efc, #6d5efc);
				color: white;
				font-weight: 600;
				text-decoration: none;
				transition: transform 0.2s ease, box-shadow 0.2s ease;
			}

			.button:hover {
				transform: translateY(-3px);
			}

			@media (max-width: 900px) {
				.layout {
					grid-template-columns: 1fr;
				}
			}

			.score {
				margin: 1rem 0 0 0;
				font-weight: 600;
				font-size: 1.1rem;
			}
		</style>
	</head>

	<body>
		<Header />

		<main>
			<article class="layout">
				<div class="hero-image">
					{heroImage && <Image src={heroImage} alt={title} width={600} height={900} />}
				</div>

				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{updatedDate && (
								<div class="last-updated-on">
									Last updated on <FormattedDate date={updatedDate} />
								</div>
							)}
						</div>
						<h1>{title}</h1>
					</div>

					<div class="description">
						{description}
					</div>

					<div class="score">
						Score:
						<span style={`color: hsl(${score * 12}, 80%, 45%)`}>
							{score}/10
						</span>
					</div>

					<slot />

					{link && (
						<a class="button" href={link} target="_blank" rel="noopener noreferrer">
							Get it
						</a>
					)}
				</div>
			</article>
		</main>

		<Footer />
	</body>
</html>