---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// Simple data-driven games list

const title = "Games";
const description = "Our games";

const games = [
	{
		name: "A NOT Troll Game",
		image: "/images/games/antg_icon.png",
		link: "/games/a-not-troll-game",
		weight: 10
	},
	{
		name: "Magic Masters",
		image: "/images/games/mm_icon.png",
		link: "/games/magic-masters",
		weight: 5
	}
];

// Sort by weight (desc)
const sortedGames = games.sort((a, b) => b.weight - a.weight);

const base = import.meta.env.BASE_URL;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />

		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}

			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}

			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}

			.title h1 {
				margin: 0 0 0.5em 0;
			}

			.grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
				gap: 1.5rem;
			}

			.card {
				position: relative;
				border-radius: 18px;
				overflow: hidden;
				cursor: pointer;
				transition: transform 0.25s ease, box-shadow 0.25s ease;
				aspect-ratio: 1 / 1;
			}

			.card:hover {
				transform: translateY(-6px);
				box-shadow: 0 16px 40px rgba(109, 94, 252, 0.25);
			}

			.card img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
			}

			.title-card {
				position: absolute;
				bottom: 0;
				width: 100%;
				padding: 1rem;
				color: white;
				font-weight: 600;
				font-size: 1rem;
				background: linear-gradient(
					to top,
					rgba(0,0,0,0.85) 0%,
					rgba(0,0,0,0.5) 40%,
					rgba(0,0,0,0) 100%
				);
				text-shadow: 0 2px 6px rgba(0,0,0,0.6);
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="prose">
					<div class="title">
						<h1>{title}</h1>
						<hr />
					</div>

					<div class="grid">
						{sortedGames.map(game => (
							<a href={base + game.link} class="card">
								<img src={base + game.image} alt={game.name} />
								<div class="title-card">{game.name}</div>
							</a>
						))}
					</div>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>